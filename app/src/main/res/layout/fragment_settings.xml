<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_soft_off_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_api_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_settings_title">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gemini API Key"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
            app:layout_constraintTop_toBottomOf="@id/til_api_key">

            <AutoCompleteTextView
                android:id="@+id/actv_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:hint="AI Model" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_test_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Test Connection"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_accent"
            app:layout_constraintTop_toBottomOf="@id/til_model"/>

        <Button
            android:id="@+id/btn_battery_opt"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Allow Background Work (Battery Opt)"
            app:layout_constraintTop_toBottomOf="@id/btn_test_connection" />

        <Button
            android:id="@+id/btn_export_data"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Export Data"
            app:layout_constraintTop_toBottomOf="@id/btn_battery_opt" />

        <Button
            android:id="@+id/btn_import_data"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Import Data"
            app:layout_constraintTop_toBottomOf="@id/btn_export_data" />

        <View
            android:id="@+id/divider_telegram"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btn_import_data" />

        <TextView
            android:id="@+id/tv_telegram_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Telegram Notifications"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/divider_telegram"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tv_telegram_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Talk to @BotFather on Telegram to create a bot and get a Bot Token."
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_telegram_settings_title"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_telegram_bot_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_telegram_instructions">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_telegram_bot_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Telegram Bot Token"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_test_telegram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Test &amp; Connect"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_accent"
            app:layout_constraintTop_toBottomOf="@id/til_telegram_bot_token"/>

        <TextView
            android:id="@+id/tv_listeners_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Listener Management"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/btn_test_telegram"
            app:layout_constraintStart_toStartOf="parent"/>

        <Button
            android:id="@+id/btn_add_listener"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Add New Listener"
            app:layout_constraintTop_toBottomOf="@id/tv_listeners_title" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_telegram_listeners"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/btn_add_listener" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
